{
  "name": "btc-dashboard",
  "description": "Bitcoin and Stock Market Dashboard",
  "homepage": "https://sinner.github.io/tradding-dashboard/",
  "private": true,
  "version": "0.2.1",
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pages:prepare": "pnpm run build && cp dist/index.html dist/404.html",
    "pages:deploy": "pnpm run pages:prepare && gh-pages -d dist",
    "git:safe": "bash scripts/safe-git.sh",
    "data:commit": "bash scripts/commit-data.sh",
    "git:clear-lock": "bash scripts/safe-git.sh status",
    "data:publish": "node scripts/publish-data.mjs"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.3.0",
    "@fontsource/ibm-plex-sans": "^5.3.0",
    "@fontsource/roboto": "^5.2.6",
    "@tanstack/react-query": "^5.83.0",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "lucide-react": "^1.26.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.7.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/d3": "^7.4.3",
    "@types/node": "^24.0.15",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "gh-pages": "^6.3.0",
    "globals": "^16.3.0",
    "only-allow": "^1.2.1",
    "postcss": "^8.5.6",
    "prettier": "^3.9.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.4"
  }
}
